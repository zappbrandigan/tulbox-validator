{
  "manifest_version": 3,
  "name": "TūlBOX Validator",
  "version": "1.0.0",
  "description": "Adds validation gates before Save or Submit Changes buttons can be used.",
  "author": "Brandon Johnson",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon16.png",
    "48": "icons/icon16.png",
    "128": "icons/icon16.png"
  },
  "content_scripts": [
    {
      "matches": ["https://works.global.umusic.net/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
